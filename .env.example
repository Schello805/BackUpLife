# BackUpLife example configuration
#
# For local/dev you can copy this file to `.env` and start the app.
# For production ALWAYS use strong random keys. Use:
#   ./scripts/init_env.sh
# to generate a secure `.env` automatically.

FLASK_SECRET_KEY=change-me

# Primary key name (fallback supported: AETERNA_APP_KEY)
BACKUPLIFE_APP_KEY=change-me-too

# Paths (fallbacks supported: AETERNA_DB_PATH / AETERNA_UPLOAD_DIR)
BACKUPLIFE_DB_PATH=instance/backuplife.db
BACKUPLIFE_UPLOAD_DIR=instance/uploads

HOST=127.0.0.1
PORT=8000

# If running behind a reverse proxy (Nginx), enable forwarded headers:
BACKUPLIFE_TRUST_PROXY=1

# If HTTPS is terminated in front of the app, set this to 1:
# BACKUPLIFE_COOKIE_SECURE=1
